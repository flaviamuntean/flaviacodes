<div id="hero">
  <div id="video-overlay"></div>
  <div id="video-wrapper">
    <video preload="auto" width="100%" height="100%" autoplay="" muted="" loop="" playsinline="" src="<%= video_path("flaviacodes-short.mov") %>"></video>
  </div>
  <div class="content">
    <h1 class="logo"> <b>Flavia</b> Muntean</h1>
    <%= render "shared/menu" %>
    <div class="text">
      <h1>Hi, I'm <span class="px-2 yellow-highlight">Flavia</span><br><span id="banner-typed-text"></span></h1>
      <div class="mdc-layout-grid">
        <div class="mdc-layout-grid__cell mdc-layout-grid__cell--span-3"></div>
        <div class="mdc-layout-grid__cell mdc-layout-grid__cell--span-6 mdc-layout-grid__cell--span-12-tablet">
          <div class="subtitle-gde">Based in the sunny part of England, I design and develop seamless solutions that bring value to people's lives.
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<%= render "shared/skills" %>
<%= render "shared/portofolio" %>
